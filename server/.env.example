# XiansAi Server Environment Configuration - DEVELOPMENT
# Copy this file to .env.local and the create-secrets.sh script will populate the secrets
# Uses standard .NET Core environment variable naming: SectionName__PropertyName

# ====================
# GENERAL SETTINGS
# ====================
ASPNETCORE_ENVIRONMENT=Development
# Container listens on HTTP only - load balancer handles SSL/TLS termination
# ASPNETCORE_URLS=http://+:8080
SERVICE_TYPE=--all
CONFIG_NAME=Local

# ====================
# DATABASE SETTINGS
# ====================
MongoDB__ConnectionString=
MongoDB__DatabaseName=xians

# ====================
# TEMPORAL WORKFLOW ENGINE
# ====================
Temporal__FlowServerUrl=host.docker.internal:7233
Temporal__FlowServerUrlExternal=localhost:7233
Temporal__FlowServerNamespace=default

# ====================
# AUTH PROVIDER SELECTION ( Will be auto-generated)
# ====================
AuthProvider__Provider=Keycloak 
Keycloak__Realm=xiansai
Keycloak__AuthServerUrl=
Keycloak__ValidIssuer=

# ====================
# CERTIFICATES (large certificate will be auto-generated)
# ====================
Certificates__AppServerPfxBase64=
Certificates__AppServerCertPassword=

# ====================
# CACHING
# ====================
Cache__Provider=memory
Cache__Redis__ConnectionString=

# ====================
# AI/LLM SETTINGS
# ====================
Llm__Provider=OpenAI
Llm__Model=gpt-4o-mini
### IMPORTANT: Set your OpenAI API key here ###
Llm__ApiKey=
########################################################

# ====================
# EMAIL SETTINGS
# ====================
Email__Provider=console
Email__Azure__ConnectionString=
Email__Azure__SenderEmail=

# ====================
# CORS SETTINGS (JSON array format)
# Use index notation for arrays: __0, __1, __2, etc.
# ====================
Cors__AllowedOrigins__1=
Cors__AllowedOrigins__2=http://localhost:3000

# ====================
# WEBSOCKETS (secrets will be auto-generated)
# ====================
WebSockets__Enabled=true

# ====================
# ENCRYPTION (keys will be auto-generated)
# ====================
EncryptionKeys__BaseSecret=
EncryptionKeys__UniqueSecrets__ConversationMessageKey=
EncryptionKeys__UniqueSecrets__TenantOidcSecretKey=
EncryptionKeys__UniqueSecrets__AppIntegrationSecretKey=

# ====================
# LOGGING (Optional - can be left in appsettings.Development.json)
# ====================
Logging__LogLevel__Default=Debug
Logging__LogLevel__Microsoft.AspNetCore=Warning

# ====================
# USAGE EVENTS 
# ====================
UsageEvents__RecordUsageEvents=true

# ====================
# OPENTELEMETRY - DEVELOPMENT MODE
# ====================
# Enable/disable OpenTelemetry observability
OpenTelemetry__Enabled=true

# Service name for telemetry identification
OpenTelemetry__ServiceName=XiansAi.Server
# Tag name used for tenant identity on all spans and log records (default: tenant.id).
#OPENTELEMETRY_TENANT_TAG_NAME=tenant.id
# Emit user identity fields (tenant.user, tenant.user_type, tenant.user_roles) as span attributes.
# OFF by default — these are PII. Enable only in trusted, internal-only observability environments.
#OpenTelemetry__IncludeUserIdentity=false

# OTLP endpoint - Aspire Dashboard in development
OpenTelemetry__OtlpEndpoint=http://aspire-dashboard:18889
# For Azure via collector, use:
# OpenTelemetry__OtlpEndpoint=http://otel-collector:4317

# Comma-separated MongoDB commands to suppress from traces.
# When not set, all commands are monitored. Uncomment and adjust as needed.
#OpenTelemetry__MongoDB__ExcludedCommands=getMore,ping
# Legacy key (supported for backward compatibility):
#OPENTELEMETRY_MONGODB_EXCLUDED_COMMANDS=getMore,ping
# Capture raw MongoDB query documents as span attributes (filter values, $match fields, etc.).
# OFF by default — query documents can contain tenant data or PII. Enable only in trusted environments.
#OpenTelemetry__MongoDB__CaptureCommandText=false
# Legacy key (supported for backward compatibility):
#OPENTELEMETRY_MONGODB_CAPTURE_COMMAND_TEXT=false

# To enable observability:
# 1. Set OpenTelemetry__Enabled=true
# 2. Start with Aspire Dashboard: docker compose --profile dev up -d
# 3. Access Aspire Dashboard at: http://localhost:18888
